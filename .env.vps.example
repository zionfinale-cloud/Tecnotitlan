# Core backend
NODE_ENV=production
PORT=5000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/DATABASE?pgbouncer=true
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
JWT_SECRET=replace-with-a-long-random-secret
CLIENT_URL_PRIMARY=https://tecnotitlan.com.mx
CLIENT_URL_SECONDARY=https://www.tecnotitlan.com.mx

# Frontend build
REACT_APP_API_URL=https://api.tecnotitlan.com.mx
REACT_APP_PAYPAL_CLIENT_ID=
REACT_APP_MERCADOLIBRE_APP_ID=
REACT_APP_MERCADOLIBRE_REDIRECT_URI=https://api.tecnotitlan.com.mx/api/mercadolibre/callback
REACT_APP_RECAPTCHA_SITE_KEY=

# Admin seed
ADMIN_EMAIL=admin@tecnotitlan.com.mx
ADMIN_PASSWORD=replace-with-at-least-12-chars

# Uploads
UPLOAD_STRATEGY=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email / support
RECAPTCHA_SECRET_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Tecnotitlan <noreply@tecnotitlan.com.mx>"
SUPPORT_EMAIL=soporte@tecnotitlan.com.mx

# Payments and integrations
PAYPAL_CLIENT_ID=
STRIPE_SECRET_KEY=
MERCADOLIBRE_APP_ID=
MERCADOLIBRE_CLIENT_SECRET=
MERCADOLIBRE_REDIRECT_URI=https://api.tecnotitlan.com.mx/api/mercadolibre/callback

# n8n
N8N_HOST=n8n.tecnotitlan.com.mx
N8N_EDITOR_BASE_URL=https://n8n.tecnotitlan.com.mx
N8N_WEBHOOK_URL=https://n8n.tecnotitlan.com.mx
N8N_ENCRYPTION_KEY=replace-with-a-long-random-secret
N8N_ORDER_WEBHOOK_URL=
N8N_SUPPORT_WEBHOOK_URL=
