{
  "name": "tecnotitlan-backend",
  "version": "1.0.0",
  "description": "Backend para la plataforma de e-commerce Tecnotitlan",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "build": "prisma generate",
    "server": "nodemon src/index.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "postinstall": "echo 'Skipping automatic prisma generate. Run manually if needed.'",
    "prisma:deploy": "npx prisma migrate deploy --schema=./prisma/schema.prisma",
    "seed:import": "node prisma/seed.js",
    "seed:destroy": "node prisma/destroy.js"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "npm run seed:import"
  },
  "dependencies": {
    "@prisma/client": "^5.17.0",
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "connect-pg-simple": "^9.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^7.4.0",
    "express-session": "^1.18.0",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "imapflow": "^1.4.3",
    "jsonwebtoken": "^9.0.2",
    "mailparser": "^3.9.12",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^6.9.13",
    "pino": "^9.0.0",
    "prisma": "^5.17.0",
    "slugify": "^1.6.6",
    "socket.io": "^4.7.5",
    "stripe": "^16.2.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
