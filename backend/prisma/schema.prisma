// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // Pooler para la app
  directUrl = env("DIRECT_URL") // Conexión directa para migraciones
}

// --- MODELOS DE LA APLICACIÓN ---

model User {
  id                String          @id @default(cuid())
  firstName         String          @map("first_name")
  lastName          String          @map("last_name")
  secondLastName    String?         @map("second_last_name")
  email             String          @unique
  password          String
  countryCode       String?         @map("country_code")
  phone             String?
  street            String?
  neighborhood      String?
  city              String?
  state             String?
  postalCode        String?         @map("postal_code")
  isVerified        Boolean         @default(false) @map("is_verified")
  verificationToken String?         @map("verification_token")
  role              Role            @relation(fields: [roleId], references: [id])
  roleId            String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  // Relaciones
  products          Product[]
  orders            Order[]
  reviews           Review[]
  supportTickets    SupportTicket[]
  inventoryInvestments InventoryInvestment[]
  inventoryMovements   InventoryMovement[]

  @@map("users")
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique // e.g., SUPER_ADMIN, VENDEDOR, USER
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  users       User[]
  permissions Permission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique // e.g., product:create, order:read
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  roles       Role[]

  @@map("permissions")
}

model Product {
  id                 String           @id @default(cuid())
  sku                String           @unique
  name               String
  description        String           @db.Text
  price              Float
  costPrice          Float?           @default(0)
  brand              String?
  countInStock       Int              @default(0)
  productType        ProductType      @default(IN_HOUSE)
  supplierInfo       String?
  shippingPayer      ShippingPayer    @default(CUSTOMER) @map("shipping_payer")
  shippingCostEstimate Float?         @default(0) @map("shipping_cost_estimate")
  weightKg           Float?           @map("weight_kg")
  lengthCm           Float?           @map("length_cm")
  widthCm            Float?           @map("width_cm")
  heightCm           Float?           @map("height_cm")
  isArchived         Boolean          @default(false)
  rating             Float            @default(0)
  numReviews         Int              @default(0)
  meliItemId         String?          @unique
  meliPublicationUrl String?
  youtubeUrl         String?          @db.Text
  lastMeliSync       DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  // Relaciones
  user               User             @relation(fields: [userId], references: [id])
  userId             String
  category           Category         @relation(fields: [categoryId], references: [id])
  categoryId         String
  media              Media[]
  characteristics    Characteristic[]
  reviews            Review[]
  orderItems         OrderItem[]
  inventoryMovements InventoryMovement[]
  marketplaceListings MarketplaceListing[]

  @@map("products")
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones jerárquicas
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  parentId String?
  children Category[] @relation("CategoryHierarchy")
  products Product[]

  @@map("categories")
}

model Order {
  id              String          @id @default(cuid())
  orderNumber     String          @unique
  itemsPrice      Float
  shippingPrice   Float
  taxPrice        Float
  paymentFee      Float
  totalPrice      Float
  isPaid          Boolean         @default(false)
  paidAt          DateTime?
  paymentMethod   String
  isDelivered     Boolean         @default(false)
  deliveredAt     DateTime?
  status          OrderStatus     @default(PENDING_PAYMENT)
  shippedAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  // Relaciones y JSON
  user            User            @relation(fields: [userId], references: [id])
  userId          String
  orderItems      OrderItem[]
  externalOrders  ExternalOrder[]
  shippingAddress Json
  paymentResult   Json?
  shippingInfo    Json?
  statusHistory   StatusHistory[]

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  name      String
  qty       Int
  image     String?
  price     Float
  unitCost  Float   @default(0) @map("unit_cost")
  // Relaciones
  order     Order   @relation(fields: [orderId], references: [id])
  orderId   String
  product   Product @relation(fields: [productId], references: [id])
  productId String

  @@map("order_items")
}

model InventoryInvestment {
  id          String              @id @default(cuid())
  name        String
  amount      Float
  notes       String?             @db.Text
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  createdBy   User?               @relation(fields: [createdById], references: [id])
  createdById String?             @map("created_by_id")
  movements   InventoryMovement[]

  @@map("inventory_investments")
}

model InventoryMovement {
  id             String                @id @default(cuid())
  type           InventoryMovementType
  quantity       Int
  unitCost       Float                 @default(0) @map("unit_cost")
  unitPrice      Float?                @map("unit_price")
  totalCost      Float                 @default(0) @map("total_cost")
  totalRevenue   Float?                @map("total_revenue")
  channel        SalesChannel?         @map("channel")
  stockBefore    Int                   @map("stock_before")
  stockAfter     Int                   @map("stock_after")
  referenceType  String?               @map("reference_type")
  referenceId    String?               @map("reference_id")
  notes          String?               @db.Text
  createdAt      DateTime              @default(now()) @map("created_at")
  product        Product               @relation(fields: [productId], references: [id])
  productId      String                @map("product_id")
  investment     InventoryInvestment?  @relation(fields: [investmentId], references: [id])
  investmentId   String?               @map("investment_id")
  createdBy      User?                 @relation(fields: [createdById], references: [id])
  createdById    String?               @map("created_by_id")

  @@index([productId, createdAt])
  @@index([type, createdAt])
  @@index([channel, createdAt])
  @@index([investmentId])
  @@map("inventory_movements")
}

model MarketplaceListing {
  id                   String                   @id @default(cuid())
  channel              SalesChannel
  externalProductId    String?                  @map("external_product_id")
  externalSku          String?                  @map("external_sku")
  title                String?
  price                Float?
  publishedStock       Int?                     @map("published_stock")
  stockBuffer          Int                      @default(0) @map("stock_buffer")
  commissionRate       Float?                   @map("commission_rate")
  shippingCostEstimate Float?                   @map("shipping_cost_estimate")
  status               MarketplaceListingStatus @default(DRAFT)
  syncStatus           String?                  @map("sync_status")
  lastSyncedAt         DateTime?                @map("last_synced_at")
  notes                String?                  @db.Text
  rawData              Json?                    @map("raw_data")
  createdAt            DateTime                 @default(now()) @map("created_at")
  updatedAt            DateTime                 @updatedAt @map("updated_at")
  product              Product                  @relation(fields: [productId], references: [id])
  productId            String                   @map("product_id")

  @@unique([productId, channel])
  @@index([channel, status])
  @@index([externalProductId])
  @@map("marketplace_listings")
}

model ExternalOrder {
  id              String       @id @default(cuid())
  channel         SalesChannel
  externalOrderId String       @map("external_order_id")
  externalStatus  String?      @map("external_status")
  customerName    String?      @map("customer_name")
  totalPrice      Float        @default(0) @map("total_price")
  shippingPrice   Float        @default(0) @map("shipping_price")
  feesEstimated   Float        @default(0) @map("fees_estimated")
  netRevenue      Float        @default(0) @map("net_revenue")
  orderedAt       DateTime?    @map("ordered_at")
  importedAt      DateTime     @default(now()) @map("imported_at")
  rawData         Json?        @map("raw_data")
  order           Order?       @relation(fields: [orderId], references: [id])
  orderId         String?      @map("order_id")

  @@unique([channel, externalOrderId])
  @@index([channel, importedAt])
  @@index([orderId])
  @@map("external_orders")
}

model Review {
  id        String   @id @default(cuid())
  name      String
  rating    Int
  comment   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // Relaciones
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  product   Product  @relation(fields: [productId], references: [id])
  productId String

  @@map("reviews")
}

model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @db.Text
  type        String   @default("string") // ej: 'string', 'color', 'boolean', 'textarea'
  description String?  @db.Text
  isEditable  Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("settings")
}

// --- MODELOS AUXILIARES ---

model Counter {
  id            String @id
  sequenceValue Int    @default(0) @map("sequence_value")

  @@map("counters")
}

model Media {
  id        String    @id @default(cuid())
  type      MediaType
  url       String
  altText   String?
  product   Product   @relation(fields: [productId], references: [id])
  productId String

  @@map("media")
}

model Characteristic {
  id        String  @id @default(cuid())
  key       String
  value     String
  product   Product @relation(fields: [productId], references: [id])
  productId String

  @@map("characteristics")
}

model StatusHistory {
  id      String   @id @default(cuid())
  status  String
  date    DateTime @default(now())
  notes   String?
  order   Order    @relation(fields: [orderId], references: [id])
  orderId String

  @@map("status_histories")
}

model SupportTicket {
  id           String              @id @default(cuid())
  ticketNumber String              @unique @map("ticket_number")
  name         String
  email        String
  phone        String?
  subject      String
  message      String              @db.Text
  source       SupportTicketSource @default(WEB)
  status       SupportTicketStatus @default(OPEN)
  priority     TicketPriority      @default(NORMAL)
  assignedTo   String?             @map("assigned_to")
  resolution   String?             @db.Text
  user         User?               @relation(fields: [userId], references: [id])
  userId       String?             @map("user_id")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@index([email])
  @@map("support_tickets")
}

// --- ENUMS ---

enum ProductType {
  IN_HOUSE
  DROPSHIPPING
}

enum ShippingPayer {
  CUSTOMER
  SELLER
  MARKETPLACE
}

enum InventoryMovementType {
  PURCHASE
  SALE
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  RETURN_IN
  RETURN_OUT
}

enum SalesChannel {
  WEB
  MERCADOLIBRE
  TIKTOK_SHOP
  AMAZON
}

enum MarketplaceListingStatus {
  DRAFT
  READY
  ACTIVE
  PAUSED
  ERROR
  ARCHIVED
}

enum OrderStatus {
  PENDING_PAYMENT
  PROCESSING
  PENDING_FULFILLMENT
  SHIPPED
  DELIVERED
  CANCELLED
}

enum MediaType {
  IMAGE
  VIDEO
}

enum SupportTicketSource {
  WEB
  EMAIL
  WHATSAPP
  BOT_ESCALATION
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CUSTOMER
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}
