// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // Pooler para la app
  directUrl = env("DIRECT_URL") // Conexión directa para migraciones
}

// --- MODELOS DE LA APLICACIÓN ---

model User {
  id                      String                   @id @default(cuid())
  customerNumber          String?                  @unique @map("customer_number")
  firstName               String                   @map("first_name")
  lastName                String                   @map("last_name")
  secondLastName          String?                  @map("second_last_name")
  email                   String                   @unique
  password                String
  countryCode             String?                  @map("country_code")
  phone                   String?
  street                  String?
  neighborhood            String?
  city                    String?
  state                   String?
  postalCode              String?                  @map("postal_code")
  isVerified              Boolean                  @default(false) @map("is_verified")
  verificationToken       String?                  @map("verification_token")
  role                    Role                     @relation(fields: [roleId], references: [id])
  roleId                  String
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  // Relaciones
  products                Product[]
  orders                  Order[]
  reviews                 Review[]
  supportTickets          SupportTicket[]
  inventoryInvestments    InventoryInvestment[]
  inventoryMovements      InventoryMovement[]
  investmentCashMovements InvestmentCashMovement[]
  tecatlConversations     ChatConversation[]
  tecatlHandoffs          ConversationHandoff[]    @relation("TecatlHandoffAssignee")
  permissionGrants        UserPermissionGrant[]
  permissionDenies        UserPermissionDeny[]

  @@map("users")
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique // e.g., SUPER_ADMIN, VENDEDOR, USER
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  users       User[]
  permissions Permission[]

  @@map("roles")
}

model Permission {
  id          String                @id @default(cuid())
  name        String                @unique // e.g., product:create, order:read
  description String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  roles       Role[]
  userGrants  UserPermissionGrant[]
  userDenies  UserPermissionDeny[]

  @@map("permissions")
}

model UserPermissionGrant {
  userId       String     @map("user_id")
  permissionId String     @map("permission_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
  @@index([permissionId])
  @@map("user_permission_grants")
}

model UserPermissionDeny {
  userId       String     @map("user_id")
  permissionId String     @map("permission_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
  @@index([permissionId])
  @@map("user_permission_denies")
}

model Product {
  id                   String               @id @default(cuid())
  sku                  String               @unique
  name                 String
  description          String               @db.Text
  price                Float
  costPrice            Float?               @default(0)
  brand                String?
  countInStock         Int                  @default(0)
  productType          ProductType          @default(IN_HOUSE)
  supplierInfo         String?
  shippingPayer        ShippingPayer        @default(CUSTOMER) @map("shipping_payer")
  shippingCostEstimate Float?               @default(0) @map("shipping_cost_estimate")
  weightKg             Float?               @map("weight_kg")
  lengthCm             Float?               @map("length_cm")
  widthCm              Float?               @map("width_cm")
  heightCm             Float?               @map("height_cm")
  isArchived           Boolean              @default(false)
  rating               Float                @default(0)
  numReviews           Int                  @default(0)
  meliItemId           String?              @unique
  meliPublicationUrl   String?
  youtubeUrl           String?              @db.Text
  lastMeliSync         DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  // Relaciones
  user                 User                 @relation(fields: [userId], references: [id])
  userId               String
  category             Category             @relation(fields: [categoryId], references: [id])
  categoryId           String
  media                Media[]
  characteristics      Characteristic[]
  reviews              Review[]
  orderItems           OrderItem[]
  inventoryMovements   InventoryMovement[]
  marketplaceListings  MarketplaceListing[]

  @@map("products")
}

model AssistantProfile {
  id              String   @id @default(cuid())
  storeId         String   @default("default") @map("store_id")
  name            String   @default("Tecatl")
  avatarUrl       String?  @map("avatar_url") @db.Text
  tone            String   @default("amable, mexicano neutro, breve, confiable")
  welcomeMessage  String   @map("welcome_message") @db.Text
  fallbackMessage String   @map("fallback_message") @db.Text
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([storeId])
  @@map("assistant_profiles")
}

model ChatConversation {
  id             String                 @id @default(cuid())
  storeId        String                 @default("default") @map("store_id")
  channel        ChatChannel
  customer       User?                  @relation(fields: [customerId], references: [id])
  customerId     String?                @map("customer_id")
  externalUserId String?                @map("external_user_id")
  customerName   String?                @map("customer_name")
  customerEmail  String?                @map("customer_email")
  status         ChatConversationStatus @default(OPEN)
  intent         String?
  lastMessageAt  DateTime?              @map("last_message_at")
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")
  messages       ChatMessage[]
  handoffs       ConversationHandoff[]

  @@index([channel, status])
  @@index([customerId])
  @@index([lastMessageAt])
  @@map("chat_conversations")
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String           @map("conversation_id")
  role           ChatMessageRole
  content        String           @db.Text
  metadata       Json?
  createdAt      DateTime         @default(now()) @map("created_at")

  @@index([conversationId, createdAt])
  @@map("chat_messages")
}

model KnowledgeArticle {
  id        String   @id @default(cuid())
  storeId   String   @default("default") @map("store_id")
  title     String
  category  String
  content   String   @db.Text
  tags      String[] @default([])
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([category, isActive])
  @@map("knowledge_articles")
}

model ConversationHandoff {
  id             String                    @id @default(cuid())
  conversation   ChatConversation          @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String                    @map("conversation_id")
  reason         String                    @db.Text
  status         ConversationHandoffStatus @default(OPEN)
  assignedUser   User?                     @relation("TecatlHandoffAssignee", fields: [assignedTo], references: [id])
  assignedTo     String?                   @map("assigned_to")
  createdAt      DateTime                  @default(now()) @map("created_at")
  resolvedAt     DateTime?                 @map("resolved_at")

  @@index([status, createdAt])
  @@map("conversation_handoffs")
}

model AssistantSetting {
  id        String   @id @default(cuid())
  storeId   String   @default("default") @map("store_id")
  key       String
  value     String   @db.Text
  type      String   @default("string")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([storeId, key])
  @@map("assistant_settings")
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones jerárquicas
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  parentId String?
  children Category[] @relation("CategoryHierarchy")
  products Product[]

  @@map("categories")
}

model Order {
  id              String          @id @default(cuid())
  orderNumber     String          @unique
  itemsPrice      Float
  shippingPrice   Float
  taxPrice        Float
  paymentFee      Float
  totalPrice      Float
  isPaid          Boolean         @default(false)
  paidAt          DateTime?
  paymentMethod   String
  isDelivered     Boolean         @default(false)
  deliveredAt     DateTime?
  status          OrderStatus     @default(PENDING_PAYMENT)
  shippedAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  // Relaciones y JSON
  user            User            @relation(fields: [userId], references: [id])
  userId          String
  orderItems      OrderItem[]
  externalOrders  ExternalOrder[]
  shippingAddress Json
  paymentResult   Json?
  shippingInfo    Json?
  statusHistory   StatusHistory[]

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  name      String
  qty       Int
  image     String?
  price     Float
  unitCost  Float   @default(0) @map("unit_cost")
  // Relaciones
  order     Order   @relation(fields: [orderId], references: [id])
  orderId   String
  product   Product @relation(fields: [productId], references: [id])
  productId String

  @@map("order_items")
}

model InventoryInvestment {
  id            String                   @id @default(cuid())
  name          String
  amount        Float
  notes         String?                  @db.Text
  createdAt     DateTime                 @default(now()) @map("created_at")
  updatedAt     DateTime                 @updatedAt @map("updated_at")
  createdBy     User?                    @relation(fields: [createdById], references: [id])
  createdById   String?                  @map("created_by_id")
  movements     InventoryMovement[]
  cashMovements InvestmentCashMovement[]

  @@map("inventory_investments")
}

model InvestmentCashMovement {
  id           String                     @id @default(cuid())
  type         InvestmentCashMovementType
  amount       Float
  notes        String?                    @db.Text
  createdAt    DateTime                   @default(now()) @map("created_at")
  investment   InventoryInvestment        @relation(fields: [investmentId], references: [id])
  investmentId String                     @map("investment_id")
  createdBy    User?                      @relation(fields: [createdById], references: [id])
  createdById  String?                    @map("created_by_id")

  @@index([investmentId, createdAt])
  @@index([type, createdAt])
  @@map("investment_cash_movements")
}

model InventoryMovement {
  id            String                @id @default(cuid())
  type          InventoryMovementType
  quantity      Int
  unitCost      Float                 @default(0) @map("unit_cost")
  unitPrice     Float?                @map("unit_price")
  totalCost     Float                 @default(0) @map("total_cost")
  totalRevenue  Float?                @map("total_revenue")
  channel       SalesChannel?         @map("channel")
  stockBefore   Int                   @map("stock_before")
  stockAfter    Int                   @map("stock_after")
  referenceType String?               @map("reference_type")
  referenceId   String?               @map("reference_id")
  notes         String?               @db.Text
  createdAt     DateTime              @default(now()) @map("created_at")
  product       Product               @relation(fields: [productId], references: [id])
  productId     String                @map("product_id")
  investment    InventoryInvestment?  @relation(fields: [investmentId], references: [id])
  investmentId  String?               @map("investment_id")
  createdBy     User?                 @relation(fields: [createdById], references: [id])
  createdById   String?               @map("created_by_id")

  @@index([productId, createdAt])
  @@index([type, createdAt])
  @@index([channel, createdAt])
  @@index([investmentId])
  @@map("inventory_movements")
}

model MarketplaceListing {
  id                   String                   @id @default(cuid())
  channel              SalesChannel
  externalProductId    String?                  @map("external_product_id")
  externalSku          String?                  @map("external_sku")
  title                String?
  price                Float?
  publishedStock       Int?                     @map("published_stock")
  stockBuffer          Int                      @default(0) @map("stock_buffer")
  commissionRate       Float?                   @map("commission_rate")
  shippingCostEstimate Float?                   @map("shipping_cost_estimate")
  status               MarketplaceListingStatus @default(DRAFT)
  syncStatus           String?                  @map("sync_status")
  lastSyncedAt         DateTime?                @map("last_synced_at")
  notes                String?                  @db.Text
  rawData              Json?                    @map("raw_data")
  createdAt            DateTime                 @default(now()) @map("created_at")
  updatedAt            DateTime                 @updatedAt @map("updated_at")
  product              Product                  @relation(fields: [productId], references: [id])
  productId            String                   @map("product_id")

  @@unique([productId, channel])
  @@index([channel, status])
  @@index([externalProductId])
  @@map("marketplace_listings")
}

model ExternalOrder {
  id              String       @id @default(cuid())
  channel         SalesChannel
  externalOrderId String       @map("external_order_id")
  externalStatus  String?      @map("external_status")
  customerName    String?      @map("customer_name")
  totalPrice      Float        @default(0) @map("total_price")
  shippingPrice   Float        @default(0) @map("shipping_price")
  feesEstimated   Float        @default(0) @map("fees_estimated")
  netRevenue      Float        @default(0) @map("net_revenue")
  orderedAt       DateTime?    @map("ordered_at")
  importedAt      DateTime     @default(now()) @map("imported_at")
  rawData         Json?        @map("raw_data")
  order           Order?       @relation(fields: [orderId], references: [id])
  orderId         String?      @map("order_id")

  @@unique([channel, externalOrderId])
  @@index([channel, importedAt])
  @@index([orderId])
  @@map("external_orders")
}

model Review {
  id        String   @id @default(cuid())
  name      String
  rating    Int
  comment   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // Relaciones
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  product   Product  @relation(fields: [productId], references: [id])
  productId String

  @@map("reviews")
}

model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @db.Text
  type        String   @default("string") // ej: 'string', 'color', 'boolean', 'textarea'
  description String?  @db.Text
  isEditable  Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("settings")
}

model TikTokShopIntegration {
  id                    String    @id @default(cuid())
  openId                String?   @map("open_id")
  sellerName            String?   @map("seller_name")
  sellerId              String?   @map("seller_id")
  shopName              String?   @map("shop_name")
  shopCipher            String?   @map("shop_cipher") @db.Text
  accessToken           String    @map("access_token") @db.Text
  refreshToken          String?   @map("refresh_token") @db.Text
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  connectedBy           String?   @map("connected_by")
  rawData               Json?     @map("raw_data")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@index([openId])
  @@map("tiktok_shop_integrations")
}

model TikTokShopWebhookEvent {
  id          String    @id @default(cuid())
  eventType   String?   @map("event_type")
  category    String?
  shopId      String?   @map("shop_id")
  shopCipher  String?   @map("shop_cipher") @db.Text
  messageId   String?   @unique @map("message_id")
  status      String    @default("RECEIVED")
  payload     Json
  headers     Json?
  receivedAt  DateTime  @default(now()) @map("received_at")
  processedAt DateTime? @map("processed_at")
  error       String?   @db.Text

  @@index([eventType, receivedAt])
  @@index([shopId])
  @@map("tiktok_shop_webhook_events")
}

// --- MODELOS AUXILIARES ---

model Counter {
  id            String @id
  sequenceValue Int    @default(0) @map("sequence_value")

  @@map("counters")
}

model Media {
  id        String    @id @default(cuid())
  type      MediaType
  url       String
  altText   String?
  product   Product   @relation(fields: [productId], references: [id])
  productId String

  @@map("media")
}

model Characteristic {
  id        String  @id @default(cuid())
  key       String
  value     String
  product   Product @relation(fields: [productId], references: [id])
  productId String

  @@map("characteristics")
}

model StatusHistory {
  id      String   @id @default(cuid())
  status  String
  date    DateTime @default(now())
  notes   String?
  order   Order    @relation(fields: [orderId], references: [id])
  orderId String

  @@map("status_histories")
}

model SupportTicket {
  id           String              @id @default(cuid())
  ticketNumber String              @unique @map("ticket_number")
  name         String
  email        String
  phone        String?
  subject      String
  message      String              @db.Text
  source       SupportTicketSource @default(WEB)
  status       SupportTicketStatus @default(OPEN)
  priority     TicketPriority      @default(NORMAL)
  assignedTo   String?             @map("assigned_to")
  resolution   String?             @db.Text
  user         User?               @relation(fields: [userId], references: [id])
  userId       String?             @map("user_id")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@index([email])
  @@map("support_tickets")
}

model WhatsAppChat {
  id            String            @id @default(cuid())
  jid           String            @unique
  phone         String?
  name          String?
  lastMessage   String?           @map("last_message") @db.Text
  unreadCount   Int               @default(0) @map("unread_count")
  lastMessageAt DateTime?         @map("last_message_at")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  messages      WhatsAppMessage[]

  @@index([lastMessageAt])
  @@map("whatsapp_chats")
}

model WhatsAppMessage {
  id            String       @id @default(cuid())
  messageId     String?      @unique @map("message_id")
  direction     String
  fromMe        Boolean      @default(false) @map("from_me")
  text          String       @db.Text
  mediaUrl      String?      @map("media_url") @db.Text
  mediaType     String?      @map("media_type")
  mediaMimeType String?      @map("media_mime_type")
  fileName      String?      @map("file_name")
  status        String       @default("RECEIVED")
  sentBy        String?      @map("sent_by")
  createdAt     DateTime     @default(now()) @map("created_at")
  chat          WhatsAppChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId        String       @map("chat_id")

  @@index([chatId, createdAt])
  @@map("whatsapp_messages")
}

// --- ENUMS ---

enum ProductType {
  IN_HOUSE
  DROPSHIPPING
}

enum ShippingPayer {
  CUSTOMER
  SELLER
  MARKETPLACE
}

enum InventoryMovementType {
  PURCHASE
  SALE
  CHANNEL_TRANSFER
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  RETURN_IN
  RETURN_OUT
}

enum InvestmentCashMovementType {
  CAPITAL_IN
  OPERATING_EXPENSE
  UNEXPECTED_EXPENSE
  CASH_OUT
  ADJUSTMENT_IN
}

enum SalesChannel {
  WEB
  MERCADOLIBRE
  TIKTOK_SHOP
  AMAZON
}

enum MarketplaceListingStatus {
  DRAFT
  READY
  ACTIVE
  PAUSED
  ERROR
  ARCHIVED
}

enum OrderStatus {
  PENDING_PAYMENT
  PROCESSING
  PENDING_FULFILLMENT
  SHIPPED
  DELIVERED
  CANCELLED
}

enum MediaType {
  IMAGE
  VIDEO
}

enum SupportTicketSource {
  WEB
  EMAIL
  WHATSAPP
  BOT_ESCALATION
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CUSTOMER
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ChatChannel {
  WEB
  WHATSAPP
  ADMIN
}

enum ChatConversationStatus {
  OPEN
  HUMAN_REQUIRED
  CLOSED
}

enum ChatMessageRole {
  USER
  ASSISTANT
  SYSTEM
  HUMAN
}

enum ConversationHandoffStatus {
  OPEN
  ASSIGNED
  RESOLVED
}
