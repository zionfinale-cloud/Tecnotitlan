FROM node:20-slim AS build

WORKDIR /app

ARG REACT_APP_API_URL
ARG REACT_APP_PAYPAL_CLIENT_ID
ARG REACT_APP_MERCADOLIBRE_APP_ID
ARG REACT_APP_MERCADOLIBRE_REDIRECT_URI
ARG REACT_APP_RECAPTCHA_SITE_KEY
ARG REACT_APP_STRIPE_PUBLISHABLE_KEY
ARG GENERATE_SOURCEMAP=false

ENV REACT_APP_API_URL=$REACT_APP_API_URL
ENV REACT_APP_PAYPAL_CLIENT_ID=$REACT_APP_PAYPAL_CLIENT_ID
ENV REACT_APP_MERCADOLIBRE_APP_ID=$REACT_APP_MERCADOLIBRE_APP_ID
ENV REACT_APP_MERCADOLIBRE_REDIRECT_URI=$REACT_APP_MERCADOLIBRE_REDIRECT_URI
ENV REACT_APP_RECAPTCHA_SITE_KEY=$REACT_APP_RECAPTCHA_SITE_KEY
ENV REACT_APP_STRIPE_PUBLISHABLE_KEY=$REACT_APP_STRIPE_PUBLISHABLE_KEY
ENV GENERATE_SOURCEMAP=$GENERATE_SOURCEMAP

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

FROM nginx:1.27-alpine

COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/build /usr/share/nginx/html
COPY docker-entrypoint.d/40-env-js.sh /docker-entrypoint.d/40-env-js.sh
RUN chmod +x /docker-entrypoint.d/40-env-js.sh

EXPOSE 80
